# 복사: cp .env.example .env.local  (Windows: copy .env.example .env.local)
# ★ 모두 서버 전용. NEXT_PUBLIC_ 접두사 절대 금지(클라이언트 노출됨).

# 기상청 (data.go.kr) — 단기예보/초단기실황/기상특보. "Decoding(일반)" 키 사용.
KMA_SERVICE_KEY=

# 한강홍수통제소 (api.hrfco.go.kr) — 하천 수위/홍수특보/강우. M1에서 사용.
HRFCO_KEY=

# 서울 열린데이터광장 (data.seoul.go.kr) — OA-1167 하천 수위현황. M1에서 사용.
SEOUL_KEY=
