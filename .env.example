# 복사: cp .env.example .env.local  (Windows: copy .env.example .env.local)
# ★ 시크릿 키는 서버 전용. NEXT_PUBLIC_ 접두사 절대 금지(클라이언트 노출됨).
#   예외: 지도 타일 키(NEXT_PUBLIC_*)는 공개 전제(도메인 바인딩) — 하단 별도 섹션 참고.

# ── 공공 API 키(시크릿) ──

# 기상청 (data.go.kr) — 단기예보/초단기실황/기상특보/부산 강우. "Decoding(일반)" 키 사용.
KMA_SERVICE_KEY=

# 한강홍수통제소 (api.hrfco.go.kr) — 하천 수위/홍수특보/강우.
HRFCO_KEY=

# 서울 열린데이터광장 (data.seoul.go.kr) — OA-1167 하천 수위현황.
SEOUL_KEY=

# 국가교통정보센터 ITS (openapi.its.go.kr) — 강·하천·교량 도로 CCTV 실시간 HLS 스트림.
# 발급: its.go.kr 회원가입 → 마이페이지 → 인증키 신청. /api/cctv 에서 사용.
# ★계정 비밀번호·실제 키 값은 이 파일에 절대 적지 말 것(public repo). 비밀번호 매니저/Vercel env에만.
ITS_KEY=

# 국립해양조사원 KHOA (해양조사원 OpenAPI) — 하구 실시간 조위.
# /api/khoa-tide·/api/litter-risk 에서 을숙도 하구 핫스팟의 조석 트랩을 실시간 보강. 없으면 정적 중립값(0.5).
KHOA_KEY=

# ── physical AI 데이터 루프 적재 경로(선택, PLAN.md §10) ──

# 관측·예측·앵커 레코드 JSONL 적재 경로(/api/observations·/api/observations/anchor·/api/litter-risk?log=1).
# 미설정 시 적재를 생략하고 응답만 반환한다. 서버리스(Vercel) 파일시스템은 휘발성이므로
# 운영 영속은 DB/Blob 경로로 둘 것(로컬·디스크 마운트 환경에서만 파일 경로 유효).
OBS_SINK_PATH=

# GPS 드리프터 궤적 JSONL 적재 경로(/api/observations/drift POST 적재, /api/litter-risk/validate 검증 입력).
# 미설정 시 드리프터 적재·검증은 비활성(엔드포인트는 NO_SINK 안내). 영속은 OBS_SINK_PATH와 동일 원칙.
DRIFT_SINK_PATH=

# ── 지도 타일 키(공개 전제 — NEXT_PUBLIC 허용, 도메인 바인딩) ──
# NakdongMap 베이스맵 전환용. 미설정 시 해당 베이스맵만 컨트롤에서 생략되고
# 키가 필요 없는 CARTO 심플·OpenTopoMap 지형은 항상 동작한다(치명적 아님).

# VWorld (국토교통부) — 한글 하천명·소하천 베이스맵.
NEXT_PUBLIC_VWORLD_KEY=

# Mapbox — 거리·라이트 베이스맵.
NEXT_PUBLIC_MAPBOX_TOKEN=
